# ═══════════════════════════════════════════════════════════════
# Fashion Affiliate Bot — Environment Variables
# Copy this file to .env and fill in all required values.
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────────────────
# Required. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# GPT model to use for captions and image filtering. Default: gpt-4o
OPENAI_MODEL=gpt-4o

# ── Google Service Account ───────────────────────────────────────
# Path to service account JSON file OR the JSON content itself (as a string).
# The service account must have access to your Sheet and Drive.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ID of the Google Sheet (from its URL: /spreadsheets/d/{SHEET_ID}/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Name of the worksheet tab (default: Products)
GOOGLE_SHEET_TAB_NAME=Products

# ── Google Drive Folder IDs ──────────────────────────────────────
# IDs from the Drive URL when you open each folder: /drive/folders/{FOLDER_ID}
# Run `python main.py setup` to auto-create these folders.
DRIVE_FOLDER_QUEUE_ID=
DRIVE_FOLDER_POSTED_ID=
DRIVE_FOLDER_REJECTED_ID=
DRIVE_FOLDER_RAW_PINTEREST_ID=

# ── Reddit ───────────────────────────────────────────────────────
# Register an app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=FashionAffiliateBot/1.0 by u/your_reddit_username
# Subreddit to post to (no r/ prefix)
REDDIT_SUBREDDIT=fashionfinds

# ── Instagram ────────────────────────────────────────────────────
# Long-lived access token from Meta Developer Portal
INSTAGRAM_ACCESS_TOKEN=
# Your Instagram Business/Creator account numeric ID
INSTAGRAM_USER_ID=

# ── YouTube ──────────────────────────────────────────────────────
# Path to OAuth 2.0 client secrets JSON from Google Cloud Console
# OR the JSON content itself as a string.
YOUTUBE_CLIENT_SECRETS_JSON=/path/to/youtube-client-secrets.json

# ── TikTok ───────────────────────────────────────────────────────
# Path to the TikTok cookie JSON file (exported from browser)
# See README for export instructions.
TIKTOK_COOKIES_PATH=data/tiktok_cookies.json

# Optional: TikTok Content Posting API access token (Strategy 1 — preferred)
# Get from https://developers.tiktok.com/ — requires Content Posting API access.
# If left empty, browser automation (Strategy 2) is used instead.
TIKTOK_ACCESS_TOKEN=

# ── Pixabay ─────────────────────────────────────────────────────
# Get free API key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── Posting Schedule ────────────────────────────────────────────
# 24-hour HH:MM format
POST_TIME_1=09:00
POST_TIME_2=14:00
POST_TIME_3=19:00

# ── Platform Toggles ────────────────────────────────────────────
# Set to false to disable a platform entirely
ENABLE_REDDIT=true
ENABLE_TIKTOK=true
ENABLE_INSTAGRAM=true
ENABLE_YOUTUBE=true

# ── Content Parameters ───────────────────────────────────────────
# Number of products per post (min and max)
MAX_PRODUCTS_PER_POST=7
MIN_PRODUCTS_PER_POST=4

# Seconds each image is shown in the slideshow video
VIDEO_SECONDS_PER_IMAGE=3

# Trigger a new Pinterest scrape when unused images fall below this count
MIN_PINTEREST_STOCK=5

# ── Pinterest Keywords ───────────────────────────────────────────
# Comma-separated search terms for Pinterest scraping
PINTEREST_KEYWORDS=streetwear outfit,aesthetic fashion,korean fashion,y2k outfit,coquette style,dark academia outfit,business casual woman

# ── File Paths (optional overrides) ─────────────────────────────
# Relative to project root by default. Absolute paths are supported.
# On Railway, attach a persistent volume and this can be left unset:
# the bot will use $RAILWAY_VOLUME_MOUNT_PATH/fashion_bot.db automatically.
SQLITE_PATH=data/fashion_bot.db
MUSIC_FOLDER=data/music
TEMP_FOLDER=data/temp
